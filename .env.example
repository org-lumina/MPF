# =============================================================
#  .env.example — SOLO NOMBRES DE VARIABLES (sin valores reales)
#  Copiá este archivo como .env.local y completá los valores.
#  REGLA DURA: ningún valor real ni credencial entra al repositorio.
#  .env* está en .gitignore.
# =============================================================

# ---- App ----
# URL pública del sitio (ej. http://localhost:3000 en desarrollo)
NEXT_PUBLIC_SITE_URL=

# ---- Google OAuth (login) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Secreto para firmar sesiones (Auth.js / NextAuth)
AUTH_SECRET=
AUTH_URL=

# ---- Mercado Pago (pago único AR$5000) ----
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Clave para validar la firma de los webhooks de Mercado Pago
MP_WEBHOOK_SECRET=

# ---- Supabase (base de datos / persistencia) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio: SOLO servidor, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=
# Cadena de conexión directa a Postgres (si se usa)
DATABASE_URL=
